{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/app-builder/spec-doc/consistency-check-output.schema.json",
  "title": "SpecConsistencyCheckOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blockingIssues",
    "followUpQuestions",
    "readinessChecklist"
  ],
  "properties": {
    "blockingIssues": {
      "type": "array",
      "description": "Authoritative list of unresolved blocking issues for this pass.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "severity"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "section": {
            "type": "string"
          }
        }
      }
    },
    "followUpQuestions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./numbered-question-item.schema.json"
      },
      "description": "Deterministically ordered numbered-options question queue for NumberedOptionsHumanRequest."
    },
    "readinessChecklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasScopeAndObjective",
        "hasNonGoals",
        "hasConstraintsAndAssumptions",
        "hasInterfacesOrContracts",
        "hasTestableAcceptanceCriteria"
      ],
      "properties": {
        "hasScopeAndObjective": {
          "type": "boolean"
        },
        "hasNonGoals": {
          "type": "boolean"
        },
        "hasConstraintsAndAssumptions": {
          "type": "boolean"
        },
        "hasInterfacesOrContracts": {
          "type": "boolean"
        },
        "hasTestableAcceptanceCriteria": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "allOf": [
          {
            "properties": {
              "readinessChecklist": {
                "properties": {
                  "hasScopeAndObjective": {
                    "const": true
                  },
                  "hasNonGoals": {
                    "const": true
                  },
                  "hasConstraintsAndAssumptions": {
                    "const": true
                  },
                  "hasInterfacesOrContracts": {
                    "const": true
                  },
                  "hasTestableAcceptanceCriteria": {
                    "const": true
                  }
                }
              }
            },
            "required": [
              "readinessChecklist"
            ]
          },
          {
            "properties": {
              "blockingIssues": {
                "maxItems": 0
              }
            },
            "required": [
              "blockingIssues"
            ]
          }
        ]
      },
      "then": {
        "properties": {
          "followUpQuestions": {
            "contains": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "completion-confirmation"
                }
              },
              "required": [
                "kind"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "followUpQuestions": {
            "contains": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "completion-confirmation"
                }
              },
              "required": [
                "kind"
              ]
            }
          }
        },
        "required": [
          "followUpQuestions"
        ]
      },
      "then": {
        "properties": {
          "blockingIssues": {
            "maxItems": 0
          },
          "readinessChecklist": {
            "properties": {
              "hasScopeAndObjective": {
                "const": true
              },
              "hasNonGoals": {
                "const": true
              },
              "hasConstraintsAndAssumptions": {
                "const": true
              },
              "hasInterfacesOrContracts": {
                "const": true
              },
              "hasTestableAcceptanceCriteria": {
                "const": true
              }
            }
          }
        }
      }
    }
  ]
}