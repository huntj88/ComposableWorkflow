{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/app-builder/spec-doc/consistency-check-output.schema.json",
  "title": "SpecConsistencyCheckOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blockingIssues",
    "followUpQuestions",
    "readinessChecklist"
  ],
  "properties": {
    "blockingIssues": {
      "type": "array",
      "description": "Authoritative list of unresolved blocking issues for this pass.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "severity"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "section": {
            "type": "string"
          }
        }
      }
    },
    "followUpQuestions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "allOf": [
          {
            "$ref": "./numbered-question-item.schema.json"
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "const": "issue-resolution"
              }
            },
            "required": [
              "kind"
            ]
          }
        ]
      },
      "description": "Deterministically ordered issue-resolution question queue from consistency check. May be empty; workflow logic synthesizes completion-confirmation when empty."
    },
    "readinessChecklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasScopeAndObjective",
        "hasNonGoals",
        "hasConstraintsAndAssumptions",
        "hasInterfacesOrContracts",
        "hasTestableAcceptanceCriteria"
      ],
      "properties": {
        "hasScopeAndObjective": {
          "type": "boolean"
        },
        "hasNonGoals": {
          "type": "boolean"
        },
        "hasConstraintsAndAssumptions": {
          "type": "boolean"
        },
        "hasInterfacesOrContracts": {
          "type": "boolean"
        },
        "hasTestableAcceptanceCriteria": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "blockingIssues": {
            "minItems": 1
          }
        },
        "required": [
          "blockingIssues"
        ]
      },
      "then": {
        "properties": {
          "followUpQuestions": {
            "minItems": 1
          }
        }
      }
    }
  ]
}