{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/app-builder/spec-doc/consistency-check-output.schema.json",
  "title": "SpecConsistencyCheckOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "nextState",
    "isImplementationReady",
    "blockingIssueCount",
    "blockingIssues",
    "followUpQuestions",
    "readinessChecklist"
  ],
  "properties": {
    "nextState": {
      "type": "string",
      "const": "NumberedOptionsHumanRequest",
      "description": "Exact target state for deterministic branching after consistency analysis. Consistency check always routes to NumberedOptionsHumanRequest; Done is intentionally excluded because completion requires explicit user confirmation."
    },
    "isImplementationReady": {
      "type": "boolean"
    },
    "blockingIssueCount": {
      "type": "integer",
      "minimum": 0
    },
    "blockingIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "severity"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": [
              "low",
              "medium",
              "high"
            ]
          },
          "section": {
            "type": "string"
          }
        }
      }
    },
    "followUpQuestions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./numbered-question-item.schema.json"
      },
      "description": "Deterministically ordered numbered-options question queue for NumberedOptionsHumanRequest."
    },
    "readinessChecklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasScopeAndObjective",
        "hasNonGoals",
        "hasConstraintsAndAssumptions",
        "hasInterfacesOrContracts",
        "hasTestableAcceptanceCriteria",
        "hasNoBlockingQuestions"
      ],
      "properties": {
        "hasScopeAndObjective": {
          "type": "boolean"
        },
        "hasNonGoals": {
          "type": "boolean"
        },
        "hasConstraintsAndAssumptions": {
          "type": "boolean"
        },
        "hasInterfacesOrContracts": {
          "type": "boolean"
        },
        "hasTestableAcceptanceCriteria": {
          "type": "boolean"
        },
        "hasNoBlockingQuestions": {
          "type": "boolean"
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "isImplementationReady": {
            "const": true
          }
        },
        "required": [
          "isImplementationReady"
        ]
      },
      "then": {
        "properties": {
          "readinessChecklist": {
            "properties": {
              "hasScopeAndObjective": {
                "const": true
              },
              "hasNonGoals": {
                "const": true
              },
              "hasConstraintsAndAssumptions": {
                "const": true
              },
              "hasInterfacesOrContracts": {
                "const": true
              },
              "hasTestableAcceptanceCriteria": {
                "const": true
              },
              "hasNoBlockingQuestions": {
                "const": true
              }
            }
          },
          "blockingIssueCount": {
            "const": 0
          },
          "blockingIssues": {
            "maxItems": 0
          },
          "followUpQuestions": {
            "contains": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "completion-confirmation"
                }
              },
              "required": [
                "kind"
              ]
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "readinessChecklist": {
            "properties": {
              "hasNoBlockingQuestions": {
                "const": true
              }
            },
            "required": [
              "hasNoBlockingQuestions"
            ]
          }
        },
        "required": [
          "readinessChecklist"
        ]
      },
      "then": {
        "properties": {
          "blockingIssueCount": {
            "const": 0
          },
          "blockingIssues": {
            "maxItems": 0
          },
          "followUpQuestions": {
            "contains": {
              "type": "object",
              "properties": {
                "kind": {
                  "const": "completion-confirmation"
                }
              },
              "required": [
                "kind"
              ]
            }
          },
          "isImplementationReady": {
            "const": true
          }
        }
      }
    }
  ]
}