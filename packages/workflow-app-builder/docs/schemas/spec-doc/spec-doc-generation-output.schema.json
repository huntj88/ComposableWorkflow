{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/app-builder/spec-doc/spec-doc-generation-output.schema.json",
  "title": "SpecDocGenerationOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "specPath",
    "summary",
    "artifacts"
  ],
  "properties": {
    "status": {
      "type": "string",
      "const": "completed"
    },
    "specPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\.md$"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "unresolvedQuestions"
      ],
      "properties": {
        "unresolvedQuestions": {
          "type": "integer",
          "const": 0
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "integrationPasses",
        "consistencyCheckPasses"
      ],
      "properties": {
        "integrationPasses": {
          "type": "integer",
          "minimum": 1
        },
        "consistencyCheckPasses": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}