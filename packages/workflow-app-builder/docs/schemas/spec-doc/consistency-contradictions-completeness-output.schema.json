{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/app-builder/spec-doc/consistency-contradictions-completeness-output.schema.json",
  "title": "SpecConsistencyContradictionsCompletenessOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "blockingIssues",
    "actionableItems",
    "followUpQuestions",
    "readinessChecklist"
  ],
  "properties": {
    "blockingIssues": {
      "type": "array",
      "items": {
        "$ref": "./consistency-check-output.schema.json#/$defs/blockingIssue"
      }
    },
    "actionableItems": {
      "type": "array",
      "minItems": 0,
      "items": {
        "$ref": "./consistency-check-output.schema.json#/$defs/specActionableItem"
      }
    },
    "followUpQuestions": {
      "type": "array",
      "minItems": 0,
      "items": {
        "allOf": [
          {
            "$ref": "./numbered-question-item.schema.json"
          },
          {
            "type": "object",
            "properties": {
              "kind": {
                "const": "issue-resolution"
              }
            },
            "required": [
              "kind"
            ]
          }
        ]
      }
    },
    "readinessChecklist": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hasNoContradictions",
        "hasSufficientDetail"
      ],
      "properties": {
        "hasNoContradictions": {
          "type": "boolean"
        },
        "hasSufficientDetail": {
          "type": "boolean"
        }
      }
    }
  }
}
