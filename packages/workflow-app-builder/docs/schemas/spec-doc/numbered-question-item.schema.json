{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/app-builder/spec-doc/numbered-question-item.schema.json",
  "title": "AppBuilderSpecDocNumberedQuestionItem",
  "allOf": [
    {
      "$ref": "../../../../workflow-server/docs/schemas/human-input/numbered-question-item.schema.json"
    },
    {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "issue-resolution",
            "completion-confirmation"
          ],
          "description": "App-builder workflow semantics layered on top of the server-owned numbered question envelope."
        },
        "options": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "description"
            ],
            "properties": {
              "description": {
                "type": "string",
                "pattern": "(?=.*Pros:)(?=.*Cons:)",
                "description": "Trade-off analysis with required 'Pros:' and 'Cons:' sections."
              }
            }
          }
        }
      }
    }
  ]
}
