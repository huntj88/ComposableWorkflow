{
  "name": "@composable-workflow/workflow-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src test",
    "test": "vitest run --passWithNoTests",
    "test:system": "vitest run test/e2e/**/*.spec.ts --passWithNoTests",
    "test:e2e": "pnpm test:e2e:blackbox",
    "test:e2e:blackbox": "vitest run test/e2e-blackbox --passWithNoTests",
    "start": "tsx src/main.ts",
    "start:test": "pnpm start",
    "migrate:up": "tsx src/persistence/migrate.ts up",
    "migrate:down": "tsx src/persistence/migrate.ts down",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@composable-workflow/workflow-lib": "workspace:*",
    "@fastify/swagger": "^9.6.1",
    "@opentelemetry/api": "^1.9.0",
    "fastify": "^5.6.1",
    "fastify-type-provider-zod": "^4.0.2",
    "pg": "^8.13.3",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/pg": "^8.11.11",
    "async-mutex": "^0.5.0",
    "node-pg-migrate": "^7.9.1",
    "testcontainers": "^10.18.0",
    "tsx": "^4.20.5"
  }
}
