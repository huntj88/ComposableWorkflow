        "id": "bi-sd-002-a",
        "description": "Authentication strategy not specified.",
        "severity": "high"
      }
    ],
    "actionableItems": [],
    "followUpQuestions": [
      {
        "questionId": "q-sd-002-a",
        "kind": "issue-resolution",
        "prompt": "Which authentication mechanism should be used?",
        "options": [
          {
            "id": 1,
            "label": "JWT tokens",
            "description": "Pros: Stateless, widely supported. Cons: Token revocation complexity."
          },
          {
            "id": 2,
            "label": "Session cookies",
            "description": "Pros: Simple server-side control. Cons: Requires sticky sessions."
          }
        ]
      },
      {
        "questionId": "q-sd-002-b",
        "kind": "issue-resolution",
        "prompt": "Should rate limiting be applied at the API gateway or application level?",
        "options": [
          {
            "id": 1,
            "label": "API gateway",
            "description": "Pros: Centralized, offloads app logic. Cons: Less granular."
          },
          {
            "id": 2,
            "label": "Application level",
            "description": "Pros: Fine-grained per-endpoint control. Cons: Increased app complexity."
          }
        ]
      }
    ],
