        "kind": "issue-resolution",
        "prompt": "Which database engine should be used?",
        "options": [
          {
            "id": 1,
            "label": "PostgreSQL",
            "description": "Pros: Mature, feature-rich relational DB. Cons: Complex scaling."
          },
          {
            "id": 2,
            "label": "SQLite",
            "description": "Pros: Zero configuration embedded DB. Cons: Limited concurrency."
          }
        ]
      },
      {
        "questionId": "q-sd-003-b",
        "kind": "issue-resolution",
        "prompt": "Should the API use REST or GraphQL?",
        "options": [
          {
            "id": 1,
            "label": "REST",
            "description": "Pros: Simple, well-understood standard. Cons: Over/under-fetching."
          },
          {
            "id": 2,
            "label": "GraphQL",
            "description": "Pros: Flexible queries for clients. Cons: Complexity in server implementation."
          }
        ]
      },
      {
        "questionId": "q-sd-003-c",
        "kind": "issue-resolution",
        "prompt": "What caching strategy should be employed?",
        "options": [
          {
            "id": 1,
            "label": "Redis",
            "description": "Pros: Fast in-memory cache, rich data structures. Cons: Extra infrastructure."
          },
          {
            "id": 2,
            "label": "In-process LRU",
            "description": "Pros: No external dependency. Cons: Not shared across instances."
          }
        ]
      }
