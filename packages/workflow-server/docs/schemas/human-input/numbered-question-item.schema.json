{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://composable-workflow.local/schemas/server/human-input/numbered-question-item.schema.json",
  "title": "HumanInputNumberedQuestionItem",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "questionId",
    "prompt",
    "options"
  ],
  "properties": {
    "questionId": {
      "type": "string",
      "minLength": 1,
      "description": "Stable question identifier for deterministic response correlation, replay, and diagnostics."
    },
    "kind": {
      "type": "string",
      "description": "Optional workflow-specific question classification tag. Transport/runtime treats this as opaque metadata."
    },
    "prompt": {
      "type": "string",
      "minLength": 1
    },
    "options": {
      "type": "array",
      "minItems": 2,
      "description": "Option IDs must be unique contiguous integers starting at 1 within each question.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "label"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}
